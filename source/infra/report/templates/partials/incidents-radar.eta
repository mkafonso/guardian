        <section
            class="mb-32 relative overflow-hidden rounded-2xl border border-pink-500/25 bg-surface-container-low shadow-2xl">
            <div class="relative p-8">
                <div class="flex items-start justify-between gap-6 flex-wrap mb-10">
                    <div>
                        <div class="flex items-center gap-3">
                            <span
                                class="material-symbols-outlined text-pink-300 bg-pink-500/10 border border-pink-500/20 rounded-xl p-2">campaign</span>
                            <h2 class="font-headline text-2xl font-bold text-on-surface">
                                Radar de Incidentes
                            </h2>
                        </div>
                    </div>
                </div>

                <% if (it.securityIncidentsError) { %>
                <div class="mt-6 rounded-xl bg-secondary/10 border border-secondary/20 p-5 text-stone-200">
                    <p class="font-headline font-bold text-secondary">
                        Radar indisponível
                    </p>
                    <p class="mt-2 text-sm text-stone-300">
                        <%= it.securityIncidentsError %>
                    </p>
                </div>
                <% } else if (it.securityIncidents && it.securityIncidents.length) { %>
                <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% for (const incident of it.securityIncidents) { %>
                    <details
                        class="group rounded-xl border border-pink-500/15 bg-surface-container-low shadow-sm hover:shadow-xl hover:border-pink-500/30 transition-all">
                        <summary class="cursor-pointer list-none p-5 flex items-start justify-between gap-4">
                            <div class="min-w-0">
                                <p class="font-headline text-lg font-bold text-on-surface truncate">
                                    <%= incident.title %>
                                </p>
                                <div class="mt-2 flex items-center gap-2 flex-wrap">
                                    <span
                                        class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-pink-500/10 text-pink-200 text-[10px] font-bold border border-pink-500/20 uppercase tracking-widest">
                                        <%= incident.type %>
                                    </span>
                                    <span
                                        class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-<%= incident.badgeColor %>/10 text-<%= incident.badgeColor %> text-[10px] font-bold border border-<%= incident.badgeColor %>/20 uppercase tracking-widest">
                                        <span class="w-1 h-1 rounded-full bg-<%= incident.badgeColor %>"></span>
                                        <%= incident.severity %>
                                    </span>
                                    <span class="text-[10px] uppercase tracking-widest text-stone-500">confiança: <%= incident.confidence %></span>
                                </div>
                            </div>

                            <span
                                class="material-symbols-outlined text-pink-200/80 group-open:rotate-180 transition-transform">expand_more</span>
                        </summary>

                        <div class="px-5 pb-5 pt-0 border-t border-pink-500/10">
                            <% if (incident.affectedEcosystem && incident.affectedEcosystem.length) { %>
                            <div class="mt-4 flex flex-wrap gap-2">
                                <% for (const eco of incident.affectedEcosystem) { %>
                                <span
                                    class="px-2 py-0.5 rounded-full bg-pink-500/10 text-pink-200 text-[10px] font-bold border border-pink-500/20"><%= eco %></span>
                                <% } %>
                            </div>
                            <% } %>
                            <% if (incident.summary) { %>
                            <p class="mt-4 text-stone-300 text-sm leading-relaxed">
                                <%= incident.summary %>
                            </p>
                            <% } %>

                            <div class="mt-4 space-y-3 text-sm text-stone-300 leading-relaxed">
                                <% if (incident.occurredAt) { %>
                                <p>
                                    <span class="text-pink-200 font-bold">Quando:</span>
                                    <%= incident.occurredAt %>
                                </p>
                                <% } %>
                                <% if (incident.sourceURL) { %>
                                <p>
                                    <span class="text-pink-200 font-bold">Fonte:</span>
                                    <a class="text-primary underline decoration-primary/40 hover:decoration-primary"
                                        href="<%= incident.sourceURL %>" target="_blank" rel="noreferrer"><%= incident.sourceURL %></a>
                                </p>
                                <% } %>
                                <% if (incident.technicalVector) { %>
                                <p>
                                    <span class="text-pink-200 font-bold">Vetor:</span>
                                    <%= incident.technicalVector %>
                                </p>
                                <% } %>
                                <% if (incident.realRisk) { %>
                                <p>
                                    <span class="text-pink-200 font-bold">Risco real:</span>
                                    <%= incident.realRisk %>
                                </p>
                                <% } %>
                                <% if (incident.detectionSignal) { %>
                                <p>
                                    <span class="text-pink-200 font-bold">Sinal:</span>
                                    <%= incident.detectionSignal %>
                                </p>
                                <% } %>
                                <% if (incident.recommendedAction) { %>
                                <p>
                                    <span class="text-pink-200 font-bold">Ação:</span>
                                    <%= incident.recommendedAction %>
                                </p>
                                <% } %>
                            </div>
                        </div>
                    </details>
                    <% } %>
                </div>

                <% if ((it.emergingPatterns && it.emergingPatterns.length) || (it.actionableInsights && it.actionableInsights.length)) { %>
                <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% if (it.emergingPatterns && it.emergingPatterns.length) { %>
                    <div class="bg-surface-container-low p-5 rounded-xl border border-pink-500/15">
                        <p class="font-headline font-bold text-pink-200">
                            Padrões emergentes
                        </p>
                        <div class="mt-3 space-y-2 text-sm text-stone-300">
                            <% for (const p of it.emergingPatterns) { %>
                            <p>• <%= p %></p>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                    <% if (it.actionableInsights && it.actionableInsights.length) { %>
                    <div class="bg-surface-container-low p-5 rounded-xl border border-pink-500/15">
                        <p class="font-headline font-bold text-pink-200">
                            Insights acionáveis
                        </p>
                        <div class="mt-3 space-y-2 text-sm text-stone-300">
                            <% for (const insight of it.actionableInsights) { %>
                            <p>• <%= insight %></p>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
                <% } %>
                <% } else { %>
                <div class="mt-6 rounded-xl bg-pink-500/10 border border-pink-500/20 p-5 text-stone-200">
                    <p class="font-headline font-bold text-pink-200">
                        Nenhum incidente retornado
                    </p>
                    <p class="mt-2 text-sm text-stone-300">
                        Gere o report com OPENAI_API_KEY configurada para preencher esta
                        seção automaticamente.
                    </p>
                </div>
                <% } %>
            </div>
        </section>
