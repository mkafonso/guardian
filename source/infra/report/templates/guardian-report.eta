<!doctype html>

<html class="dark" lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Guardian Report</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "outline-variant": "#3c4a42",
                        "surface-container-highest": "#373433",
                        "on-primary-fixed": "#002113",
                        surface: "#151312",
                        outline: "#86948a",
                        "on-secondary-container": "#ffc2c4",
                        "on-secondary-fixed": "#40000d",
                        "secondary-fixed": "#ffdadb",
                        "secondary-container": "#b50036",
                        "on-background": "#e8e1df",
                        error: "#ffb4ab",
                        "error-container": "#93000a",
                        secondary: "#ffb2b7",
                        "on-primary-container": "#00422b",
                        "primary-fixed-dim": "#4edea3",
                        "inverse-surface": "#e8e1df",
                        "on-surface": "#e8e1df",
                        "tertiary-container": "#e29100",
                        "surface-bright": "#3c3837",
                        "on-secondary-fixed-variant": "#92002a",
                        "surface-tint": "#4edea3",
                        "on-primary-fixed-variant": "#005236",
                        "primary-fixed": "#6ffbbe",
                        "surface-dim": "#151312",
                        "on-error-container": "#ffdad6",
                        "on-secondary": "#67001b",
                        "surface-container-high": "#2c2928",
                        "on-tertiary": "#472a00",
                        primary: "#4edea3",
                        "on-tertiary-fixed": "#2a1700",
                        "surface-container-low": "#1d1b1a",
                        "surface-variant": "#373433",
                        "on-tertiary-container": "#523200",
                        "on-primary": "#003824",
                        "surface-container-lowest": "#100e0d",
                        "secondary-fixed-dim": "#ffb2b7",
                        "on-error": "#690005",
                        "tertiary-fixed": "#ffddb8",
                        tertiary: "#ffb95f",
                        "inverse-primary": "#006c49",
                        "surface-container": "#221f1e",
                        "on-tertiary-fixed-variant": "#653e00",
                        "on-surface-variant": "#bbcabf",
                        "inverse-on-surface": "#33302e",
                        "primary-container": "#10b981",
                        "tertiary-fixed-dim": "#ffb95f",
                        background: "#151312",
                    },
                    borderRadius: {
                        DEFAULT: "0.125rem",
                        lg: "0.25rem",
                        xl: "0.5rem",
                        full: "0.75rem",
                    },
                    fontFamily: {
                        headline: ["Space Grotesk"],
                        body: ["Inter"],
                        label: ["Inter"],
                    },
                },
            },
        };
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings:
                "FILL" 0,
                "wght" 400,
                "GRAD" 0,
                "opsz" 24;
        }

        .glass-panel {
            background: rgba(34, 31, 30, 0.6);
            backdrop-filter: blur(20px);
        }

        .collapsible-card {
            cursor: pointer;
        }

        .collapsible-content {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
            transition:
                max-height 450ms ease,
                opacity 350ms ease,
                margin-top 350ms ease;
            margin-top: 0;
        }

        .collapsible-card.expanded .collapsible-content {
            max-height: 420px;
            opacity: 1;
            margin-top: 1.25rem;
        }

        .collapsible-placeholder {
            opacity: 1;
            max-height: 64px;
            margin-top: 1rem;
            overflow: hidden;
            transition:
                opacity 220ms ease,
                max-height 220ms ease,
                margin-top 220ms ease;
        }

        .collapsible-card.expanded .collapsible-placeholder {
            opacity: 0;
            max-height: 0;
            margin-top: 0;
        }

        .collapsible-chevron {
            transition: transform 300ms ease;
        }

        .collapsible-card.expanded .collapsible-chevron {
            transform: rotate(180deg);
        }
    </style>
</head>

<body class="bg-surface text-on-surface font-body selection:bg-primary selection:text-on-primary container mx-auto">
    <main class="pt-24 pb-12 px-8 min-h-screen">
<%~ include("./partials/header.eta", it) %>
<%~ include("./partials/summary-cards.eta", it) %>
<%~ include("./partials/critical-risks.eta", it) %>
<%~ include("./partials/maintenance-risks.eta", it) %>
<%~ include("./partials/safe-updates.eta", it) %>
<%~ include("./partials/incidents-radar.eta", it) %>
    </main>

    <script>
        const toggleCard = (card) => {
            const isExpanded = card.classList.toggle("expanded");
            card.setAttribute("aria-expanded", String(isExpanded));
        };

        document.querySelectorAll("[data-collapsible-card]").forEach((card) => {
            card.addEventListener("click", () => toggleCard(card));
            card.addEventListener("keydown", (event) => {
                if (event.key === "Enter" || event.key === " ") {
                    event.preventDefault();
                    toggleCard(card);
                }
            });
        });
    </script>
</body>

</html>
