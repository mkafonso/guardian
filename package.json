{
  "name": "guardian",
  "version": "0.1.0",
  "description": "A CLI tool that analyzes Node.js dependencies, prioritizes risks, and generates actionable HTML reports.",
  "type": "module",
  "license": "MIT",
  "author": "mkafonso <mkafonso.dev@gmail.com>",
  "homepage": "https://github.com/mkafonso/guardian",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkafonso/guardian.git"
  },
  "bugs": {
    "url": "https://github.com/mkafonso/guardian/issues"
  },
  "keywords": [
    "security",
    "dependencies",
    "npm",
    "audit",
    "vulnerabilities",
    "cli",
    "typescript",
    "dependency-analysis",
    "devtools",
    "nodejs"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "guardian": "./dist/infra/interfaces/cli/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx source/infra/interfaces/cli/index.ts analyze",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "eta": "4.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.6.0",
    "tsdown": "0.21.9",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
