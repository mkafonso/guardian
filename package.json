{
  "name": "@mkafonso/guardian",
  "version": "0.1.4",
  "description": "A CLI tool that analyzes Node.js dependencies, prioritizes risks, and generates actionable HTML reports.",
  "license": "MIT",
  "author": "mkafonso <mkafonso.dev@gmail.com>",
  "homepage": "https://github.com/mkafonso/guardian",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkafonso/guardian.git"
  },
  "bugs": {
    "url": "https://github.com/mkafonso/guardian/issues"
  },
  "keywords": [
    "security",
    "dependencies",
    "npm",
    "audit",
    "vulnerabilities",
    "cli",
    "typescript",
    "dependency-analysis",
    "devtools",
    "nodejs"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "guardian": "./dist/index.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "npm run build && npm unlink -g guardian && npm link && guardian analyze",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "eta": "4.6.0",
    "picocolors": "1.1.1",
    "yocto-spinner": "1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "25.6.0",
    "dotenv": "17.4.2",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
